  },
  {
    "name": "di_system_capture_start",
    "patterns": [{"pattern": "^System information for the (.+) system:$", "type": "regex"}]
  },
  {
    "name": "explore_system_closed",
    "patterns": [{"pattern": "^I'm afraid the (.+) system is closed to visitors at the moment\\.$", "type": "regex"}]
  },
  {
    "name": "jump_no_direct_link",
    "patterns": [{"pattern": "^There isn't a direct link to (.+) from here\\.$", "type": "regex"}]
  },
  {
    "name": "special_exit_invalid_command",
    "patterns": [{"pattern": "^I'm sorry I don't understand you\\. Can you put that a different way\\?$", "type": "regex"}]
